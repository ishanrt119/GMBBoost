{
  "name": "AI Lead Follow-Up Automation",
  "nodes": [
    {
      "parameters": {
        "path": "lead-followup",
        "options": {}
      },
      "id": "a1b2c3d4-1111-2222-3333-444455556666",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        100,
        300
      ],
      "webhookId": "c3d4e5f6-abcd-1234-xyz-0987654321"
    },
    {
      "parameters": {
        "amount": 5,
        "unit": "seconds"
      },
      "id": "b2c3d4e5-2222-3333-4444-555566667777",
      "name": "Wait 5s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        300,
        300
      ],
      "webhookId": "wait-node-1"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.twilio.com/2010-04-01/Accounts/{{$env.TWILIO_ACCOUNT_SID}}/Messages.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "basicAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "To",
              "value": "=whatsapp:+{{$json.body.phone}}"
            },
            {
              "name": "From",
              "value": "={{$env.TWILIO_WHATSAPP_NUMBER}}"
            },
            {
              "name": "Body",
              "value": "=Hi {{$json.body.leadName}}, thanks for contacting us! Our AI Sales Team will help you shortly."
            }
          ]
        },
        "options": {}
      },
      "id": "c3d4e5f6-3333-4444-5555-666677778888",
      "name": "Welcome Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        500,
        300
      ],
      "credentials": {
        "basicAuth": {
          "id": "twilio-auth",
          "name": "Twilio Basic Auth"
        }
      }
    },
    {
      "parameters": {
        "amount": 3,
        "unit": "days"
      },
      "id": "d4e5f6a7-4444-5555-6666-777788889999",
      "name": "Wait 3 Days",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        700,
        300
      ],
      "webhookId": "wait-node-2"
    },
    {
      "parameters": {
        "url": "={{$env.GMB_API_URL}}/api/crm/leads/{{$node[\"Webhook Trigger\"].json.body.leadId}}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "e5f6a7b8-5555-6666-7777-888899990000",
      "name": "Check Lead Status 1",
