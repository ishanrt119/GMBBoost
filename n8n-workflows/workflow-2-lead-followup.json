      "position": [
        900,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "gmb-api-key",
          "name": "GMB API Key"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.lead.pipelineStage}}",
              "operation": "notEqual",
              "value2": "Converted"
            },
            {
              "value1": "={{$json.lead.pipelineStage}}",
