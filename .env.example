# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/gmb-ai

# Auth
JWT_SECRET=your_jwt_secret_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth & Business Profile
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# AI & APIs
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=gsk_your_groq_key
SERPAPI_KEY=your_serpapi_key

# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# n8n Automation
N8N_WEBHOOK_URL=http://localhost:5678/webhook/

# Cron
CRON_SECRET=your_cron_secret_here

# OpenAI (Required for AI Audit Engine)
OPENAI_API_KEY=

# Inngest (Required for Background Jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Email Services
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME="Your Business Name"

# Review System & Monitoring
GOOGLE_REVIEW_LINK_BASE=https://g.page/r/fallback/review
GOOGLE_REVIEW_API_KEYS=your_google_review_api_key

GOOGLE_MAPS_API_KEY=""
